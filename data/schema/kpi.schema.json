{
  "$ref": "#/definitions/KpiSource",
  "definitions": {
    "KpiSource": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "section": {
          "type": "string",
          "enum": [
            "business",
            "acquisition",
            "product",
            "basket",
            "checkout",
            "performance",
            "fulfillment",
            "retention",
            "cost"
          ]
        },
        "definition": {
          "type": "string",
          "minLength": 1
        },
        "formula": {
          "type": "string",
          "minLength": 1
        },
        "unit": {
          "type": "string",
          "enum": [
            "%",
            "currency",
            "count",
            "ratio",
            "seconds",
            "ms",
            "days",
            "months",
            "KB",
            "rating",
            "nps"
          ]
        },
        "parents": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
              },
              "relationship": {
                "type": "string",
                "enum": [
                  "multiplicative",
                  "additive",
                  "inverse",
                  "cost",
                  "driver"
                ]
              },
              "note": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "id",
              "relationship"
            ],
            "additionalProperties": false
          }
        },
        "levers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "action": {
                "type": "string",
                "minLength": 1
              },
              "impact": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high"
                ]
              },
              "effort": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high"
                ]
              },
              "description": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "action",
              "impact",
              "effort"
            ],
            "additionalProperties": false
          }
        },
        "benchmarks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string",
                "minLength": 1
              },
              "value": {
                "type": "string",
                "minLength": 1
              },
              "source": {
                "type": "string",
                "format": "uri"
              },
              "note": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "label",
              "value",
              "source"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "id",
        "name",
        "section",
        "definition",
        "formula",
        "unit",
        "parents",
        "levers",
        "benchmarks"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
