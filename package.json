{
  "name": "commerce-kpi-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "DIGITALL Webshop KPI Explorer — interactive decomposition of e-commerce KPIs from operational levers up to money earned and money saved.",
  "scripts": {
    "build:data": "tsx scripts/build-data.ts",
    "validate:data": "tsx scripts/build-data.ts --check",
    "dev": "npm run build:data && vite",
    "build": "npm run build:data && tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@xyflow/react": "^12.3.5",
    "elkjs": "^0.9.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.5",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  }
}
